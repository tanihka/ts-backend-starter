{
  "compilerOptions": {
    // ── Output ──────────────────────────────────────────────────────────
    "target": "ES2020",          // Node 14+ supports ES2020 natively
    "module": "CommonJS",        // Node.js CJS interop (no ESM headaches)
    "lib": ["ES2020"],
    "outDir": "./dist",          // Compiled JS goes here
    "rootDir": "./src",          // All TS source lives in src/

    // ── Strict correctness ───────────────────────────────────────────────
    "strict": true,              // Enables all strict checks (noImplicitAny, etc.)
    "noUncheckedIndexedAccess": true,  // obj[key] is T | undefined — safer arrays/maps
    "noImplicitReturns": true,   // Every code path must return a value
    "noFallthroughCasesInSwitch": true,

    // ── Interop ──────────────────────────────────────────────────────────
    "esModuleInterop": true,     // import express from 'express' (not import * as)
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,        // Skip type-checking .d.ts files (avoids @types conflicts)
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,   // import data from './data.json'

    // ── Developer experience ──────────────────────────────────────────────
    "sourceMap": true,           // Stack traces map back to .ts files
    "declaration": true          // Emit .d.ts files alongside compiled JS
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
