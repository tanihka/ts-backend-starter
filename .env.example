# Copy this file to .env and fill in real values.
# .env is git-ignored. NEVER commit real secrets.

NODE_ENV=development
PORT=3000

# MongoDB connection string
# Local example:  mongodb://localhost:27017/app
# Atlas example:  mongodb+srv://user:pass@cluster.mongodb.net/app
MONGODB_URI=mongodb://localhost:27017/app

# CORS — comma-separated allowed origins (defaults to Vite dev server)
ALLOWED_ORIGINS=http://localhost:5173

# 2Factor SMS — get your API key from https://2factor.in
TWO_FACTOR_API_KEY=your_2factor_api_key_here
TWO_FACTOR_SENDER_ID=INSUGX
TWO_FACTOR_TEMPLATE_NAME=OTP_INSUGX
